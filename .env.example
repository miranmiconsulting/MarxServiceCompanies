# Public site URL (used in metadata, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://www.alamoareagutterhelmet.com

# Optional: enable real email delivery from the contact form via Resend (https://resend.com)
# If unset, the contact form still works — submissions are just logged to the server console.
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@alamoareagutters.com
CONTACT_FROM_EMAIL=website@alamoareagutterhelmet.com
